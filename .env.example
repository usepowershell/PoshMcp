# PoshMcp Docker Build Configuration
# Copy this file to .env and customize for your needs

# ============================================================================
# PowerShell Module Installation (Build Time)
# ============================================================================

# Pre-install PowerShell modules at Docker build time for faster container startup
# Format: Space or comma-separated list of module names with optional version constraints
# 
# Syntax:
#   ModuleName             - Install latest version
#   ModuleName@1.2.3       - Install specific version  
#   ModuleName@>=1.0.0     - Install minimum version
#   ModuleName@<=2.0.0     - Install maximum version

# Example 1: Basic modules (no versions)
# INSTALL_PS_MODULES="Pester PSScriptAnalyzer"

# Example 2: Azure modules with version constraints
# INSTALL_PS_MODULES="Az.Accounts@>=2.0.0 Az.Resources Az.Storage"

# Example 3: Mixed list (comma or space separated)
# INSTALL_PS_MODULES="Pester@5.5.0,Az.Accounts@>=2.0.0,PSScriptAnalyzer"

# Example 4: Testing and quality modules
# INSTALL_PS_MODULES="Pester@>=5.0.0 PSScriptAnalyzer Plaster"

# Example 5: No modules (empty - modules installed at runtime via appsettings.json)
INSTALL_PS_MODULES=""

# ============================================================================
# Module Installation Options
# ============================================================================

# Scope: Where to install modules
#   AllUsers    - Install for all users (requires root, persists in image)
#   CurrentUser - Install for current user only
MODULE_INSTALL_SCOPE="AllUsers"

# Skip publisher check during installation
#   true  - Skip validation (faster, less secure)
#   false - Validate publisher (slower, more secure)
SKIP_PUBLISHER_CHECK="true"

# ============================================================================
# Docker Build Configuration
# ============================================================================

# Docker image name
IMAGE_NAME="poshmcp"

# Docker registry (optional - for pushing to private registry)
# DOCKER_REGISTRY="myregistry.azurecr.io"

# ============================================================================
# Usage Examples
# ============================================================================

# Build with no pre-installed modules:
#   docker build -t poshmcp .
#   ./docker.sh build

# Build with modules from environment:
#   export INSTALL_PS_MODULES="Pester PSScriptAnalyzer"
#   ./docker.sh build

# Build with modules from command line:
#   ./docker.sh build --modules "Pester PSScriptAnalyzer"
#   ./docker.sh build --modules "Az.Accounts@2.0.0 Pester@>=5.0.0"

# Build with modules from .env file:
#   1. Copy this file to .env
#   2. Uncomment and set INSTALL_PS_MODULES
#   3. Run: docker build --build-arg INSTALL_PS_MODULES="$INSTALL_PS_MODULES" -t poshmcp .

# ============================================================================
# Runtime Configuration (appsettings.json)
# ============================================================================

# After building with pre-installed modules, update your appsettings.json
# to use ImportModules instead of InstallModules for faster startup:
#
# {
#   "PowerShellConfiguration": {
#     "Environment": {
#       "ImportModules": ["Pester", "Az.Accounts"],  // Fast - already installed
#       "InstallModules": []                          // Empty - skip installation
#     }
#   }
# }

# ============================================================================
# Multi-Stage Approach (Recommended for Production)
# ============================================================================

# 1. Build-time: Pre-install stable, required modules (this file)
#    Example: INSTALL_PS_MODULES="Az.Accounts@2.12.0 PSScriptAnalyzer@1.21.0"
#
# 2. Runtime: Install optional, frequently-changing modules (appsettings.json)
#    Example: "InstallModules": [{"Name": "CustomModule", "Version": "1.0.0"}]
#
# This hybrid approach balances:
#   - Fast startup (pre-installed modules)
#   - Flexibility (runtime modules)
#   - Image size (only core modules in image)
