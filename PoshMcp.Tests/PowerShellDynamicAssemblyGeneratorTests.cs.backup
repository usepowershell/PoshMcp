using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.Linq;
using System.Management.Automation;
using System.Reflection;
using System.Threading;
using System.Threading.Tasks;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Logging.Console;
using Xunit;
using Xunit.Abstractions;

namespace PoshMcp.Tests;

/// <summary>
/// Unit tests for the PowerShell Dynamic Assembly Generator
/// </summary>
public class PowerShellDynamicAssemblyGeneratorTests : IDisposable
{
    private readonly ILogger _logger;
    private readonly ITestOutputHelper _output;

    public PowerShellDynamicAssemblyGeneratorTests(ITestOutputHelper output)
    {
        _output = output;

        // Create a logger that writes to test output
        var loggerFactory = LoggerFactory.Create(builder =>
        {
            builder.AddProvider(new TestOutputLoggerProvider(output));
            builder.SetMinimumLevel(LogLevel.Debug);
        });

        _logger = loggerFactory.CreateLogger<PowerShellDynamicAssemblyGeneratorTests>();

        // Clear any existing cache before each test to ensure isolation
        PowerShellDynamicAssemblyGenerator.ClearCache();
    }

    /// <summary>
    /// Clean up after each test to ensure no state pollution
    /// </summary>
    public void Dispose()
    {
        // Clear the cache after each test to prevent interference between tests
        PowerShellDynamicAssemblyGenerator.ClearCache();

        // Clear PowerShell runspace state as well
        try
        {
            var powerShell = PowerShellRunspaceHolder.Instance;
            powerShell.Commands.Clear();
            if (powerShell.HadErrors)
            {
                powerShell.Streams.Error.Clear();
            }
        }
        catch
        {
            // Ignore cleanup errors
        }
    }

    [Fact]
    public void GenerateAssembly_ShouldCreateValidAssembly()
    {
        // Arrange
        var commands = GetTestCommands();

        // Act
        var assembly = PowerShellDynamicAssemblyGenerator.GenerateAssembly(commands, _logger);

        // Assert
        Assert.NotNull(assembly);
        Assert.True(assembly.IsDynamic);
        Assert.NotEmpty(assembly.GetTypes());

        _output.WriteLine($"Generated assembly: {assembly.FullName}");
        _output.WriteLine($"Assembly is dynamic: {assembly.IsDynamic}");
    }

    [Fact]
    public void GetGeneratedMethods_ShouldReturnMethodsForCommands()
    {
        // Arrange
        var commands = GetTestCommands();

        // Act
        PowerShellDynamicAssemblyGenerator.GenerateAssembly(commands, _logger);
        var methods = PowerShellDynamicAssemblyGenerator.GetGeneratedMethods();

        // Assert
        Assert.NotNull(methods);
        Assert.NotEmpty(methods);

        foreach (var kvp in methods)
        {
            var methodName = kvp.Key;
            var method = kvp.Value;

            _output.WriteLine($"Method: {methodName}");
            _output.WriteLine($"  Return type: {method.ReturnType.Name}");
            _output.WriteLine($"  Parameters: {method.GetParameters().Length}");

            // Verify method signature
            Assert.Equal(typeof(Task<string>), method.ReturnType);
            Assert.True(method.GetParameters().Length > 0); // Should have at least CancellationToken

            // Verify last parameter is CancellationToken
            var lastParam = method.GetParameters().Last();
            Assert.Equal(typeof(CancellationToken), lastParam.ParameterType);
            Assert.Equal("cancellationToken", lastParam.Name);
        }
    }

    [Fact]
    public void GetGeneratedInstance_ShouldReturnValidInstance()
    {
        // Arrange
        var commands = GetTestCommands();

        // Act
        PowerShellDynamicAssemblyGenerator.GenerateAssembly(commands, _logger);
        var instance = PowerShellDynamicAssemblyGenerator.GetGeneratedInstance(_logger);

        // Assert
        Assert.NotNull(instance);

        var instanceType = instance.GetType();
        _output.WriteLine($"Instance type: {instanceType.Name}");
        _output.WriteLine($"Instance namespace: {instanceType.Namespace}");

        // Verify instance has expected methods
        var methods = instanceType.GetMethods(BindingFlags.Public | BindingFlags.Instance)
            .Where(m => m.DeclaringType == instanceType && m.Name != ".ctor")
            .ToList();

        Assert.NotEmpty(methods);
        _output.WriteLine($"Instance has {methods.Count} public methods");
    }

    [Fact]
    public async Task GeneratedMethod_ShouldBeCallableDirectly()
    {
        // Arrange
        SetupTestPowerShellFunction();
        var commands = GetTestCommands();

        // Act
        PowerShellDynamicAssemblyGenerator.GenerateAssembly(commands, _logger);
        var instance = PowerShellDynamicAssemblyGenerator.GetGeneratedInstance(_logger);
        var methods = PowerShellDynamicAssemblyGenerator.GetGeneratedMethods();

        // Get the first method (should be Get_SomeOtherData)
        var firstMethod = methods.First();
        var methodName = firstMethod.Key;
        var method = firstMethod.Value;

        _output.WriteLine($"Testing method: {methodName}");

        // Prepare parameters (all parameters except CancellationToken)
        var parameters = method.GetParameters().Take(method.GetParameters().Length - 1).ToArray();
        var args = new List<object>();

        foreach (var param in parameters)
        {
            if (param.ParameterType == typeof(string))
            {
                args.Add("TestValue");
            }
            else if (param.ParameterType == typeof(int) || param.ParameterType == typeof(int?))
            {
                args.Add(42);
            }
            else
            {
                args.Add(null!);
            }
        }

        // Add CancellationToken
        args.Add(CancellationToken.None);

        // Act
        var result = method.Invoke(instance, args.ToArray());

        // Assert
        Assert.NotNull(result);

        // Handle both Task<string> and AsyncTaskMethodBuilder cases
        Task<string> taskResult;
        if (result is Task<string> directTask)
        {
            taskResult = directTask;
        }
        else
        {
            // For AsyncTaskMethodBuilder, we need to get the Task
            var taskProperty = result.GetType().GetProperty("Task");
            if (taskProperty != null)
            {
                taskResult = (Task<string>)taskProperty.GetValue(result)!;
            }
            else
            {
                // Fallback: convert to Task<string>
                taskResult = Task.FromResult(result.ToString() ?? "");
            }
        }

        var output = await taskResult;

        Assert.NotNull(output);
        _output.WriteLine($"Method output: {output}");

        // Verify output contains expected content (the function returns "Data item X for Y")
        Assert.True(output.Contains("Data item") &&
                   (output.Contains("TestValue") || output.Contains("DefaultName") || output.Contains("SilentlyContinue")),
                   $"Expected output to contain 'Data item' and a parameter value, but got: {output}");
    }

    [Fact]
    public void GeneratedMethod_ShouldHandleParameterTypes()
    {
        // Arrange
        SetupTestPowerShellFunction();
        var commands = GetTestCommands();

        PowerShellDynamicAssemblyGenerator.GenerateAssembly(commands, _logger);
        var methods = PowerShellDynamicAssemblyGenerator.GetGeneratedMethods();

        foreach (var kvp in methods)
        {
            var methodName = kvp.Key;
            var method = kvp.Value;

            _output.WriteLine($"\nTesting parameter types for method: {methodName}");

            var parameters = method.GetParameters();

            foreach (var param in parameters)
            {
                _output.WriteLine($"  Parameter: {param.Name} ({param.ParameterType.Name})");

                // Verify parameter has a name
                Assert.False(string.IsNullOrEmpty(param.Name), $"Parameter in method {methodName} has no name");

                // Verify parameter type is supported
                Assert.True(IsSupportedParameterType(param.ParameterType),
                    $"Unsupported parameter type {param.ParameterType.Name} in method {methodName}");
            }
        }
    }

    [Fact]
    public async Task ExecutePowerShellCommand_ShouldHandleValidCommand()
    {
        // Arrange
        SetupTestPowerShellFunction();

        var parameterInfos = new[]
        {
            new PowerShellParameterInfo("Name", typeof(string), false),
            new PowerShellParameterInfo("Count", typeof(int), false)
        };

        var parameterValues = new object[] { "TestUser", 3 };

        // Act
        var result = await PowerShellDynamicAssemblyGenerator.ExecutePowerShellCommand(
            "Get-SomeOtherData",
            parameterInfos,
            parameterValues,
            CancellationToken.None,
            _logger);

        // Assert
        Assert.NotNull(result);
        _output.WriteLine($"Command result: {result}");

        // Should either contain our test data or an error message
        Assert.True(result.Contains("TestUser") || result.Contains("Error") || result.Contains("Command"));
    }

    [Fact]
    public async Task ExecutePowerShellCommand_ShouldHandleInvalidCommand()
    {
        // Arrange
        var parameterInfos = new PowerShellParameterInfo[0];
        var parameterValues = new object[0];

        // Act
        var result = await PowerShellDynamicAssemblyGenerator.ExecutePowerShellCommand(
            "NonExistentCommand",
            parameterInfos,
            parameterValues,
            CancellationToken.None,
            _logger);

        // Assert
        Assert.NotNull(result);
        _output.WriteLine($"Error result: {result}");
        Assert.Contains("Error", result);
    }

    private List<CommandInfo> GetTestCommands()
    {
        try
        {
            SetupTestPowerShellFunction();

            var powerShell = PowerShellRunspaceHolder.Instance;
            var commands = new List<CommandInfo>();

            // Try to get the test command
            powerShell.Commands.Clear();
            powerShell.AddCommand("Get-Command").AddParameter("Name", "Get-SomeOtherData");
            var cmdInfo = powerShell.Invoke<CommandInfo>().FirstOrDefault();
            powerShell.Commands.Clear();

            if (cmdInfo != null)
            {
                commands.Add(cmdInfo);
                _output.WriteLine($"Found test command: {cmdInfo.Name}");
            }
            else
            {
                _output.WriteLine("Test command not found, creating mock command info");
                // For testing purposes, we'll still return an empty list
                // The test should handle this gracefully
            }

            return commands;
        }
        catch (Exception ex)
        {
            _output.WriteLine($"Error getting test commands: {ex.Message}");
            return new List<CommandInfo>();
        }
    }

    private void SetupTestPowerShellFunction()
    {
        try
        {        // Clear any existing functions first
            var clearScript = @"
# Remove any existing Get-SomeData or Get-SomeOtherData functions
if (Get-Command Get-SomeData -ErrorAction SilentlyContinue) { Remove-Item function:Get-SomeData }
if (Get-Command Get-SomeOtherData -ErrorAction SilentlyContinue) { Remove-Item function:Get-SomeOtherData }
";

            var testFunctionScript = @"
function Get-SomeOtherData {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$false, Position=0)]
        [string]$Name = 'DefaultName',
        
        [Parameter(Mandatory=$false, Position=1)]
        [int]$Count = 1
    )
    
    $result = @()
    for ($i = 1; $i -le $Count; $i++) {
        $result += ""Data item $i for $Name""
    }
    
    return $result -join ""`n""
}";

            var powerShell = PowerShellRunspaceHolder.Instance;
            powerShell.Commands.Clear();

            // First clear existing functions
            powerShell.AddScript(clearScript);
            powerShell.Invoke();
            powerShell.Commands.Clear();

            // Then add our test function
            powerShell.AddScript(testFunctionScript);
            powerShell.Invoke();
            powerShell.Commands.Clear();

            if (powerShell.HadErrors)
            {
                var errors = powerShell.Streams.Error.ReadAll();
                _output.WriteLine($"Errors setting up test function: {string.Join("; ", errors)}");
                powerShell.Streams.Error.Clear();
            }
            else
            {
                _output.WriteLine("Test PowerShell function set up successfully");
            }
        }
        catch (Exception ex)
        {
            _output.WriteLine($"Exception setting up test function: {ex.Message}");
        }
    }

    private static bool IsSupportedParameterType(Type type)
    {
        // Handle nullable types
        if (type.IsGenericType && type.GetGenericTypeDefinition() == typeof(Nullable<>))
        {
            var underlyingType = Nullable.GetUnderlyingType(type);
            return underlyingType != null && IsSupportedParameterType(underlyingType);
        }

        // List of supported parameter types
        var supportedTypes = new[]
        {
            typeof(string),
            typeof(int), typeof(bool), typeof(double), typeof(decimal), typeof(DateTime),
            typeof(SwitchParameter),
            typeof(CancellationToken)
        };

        return supportedTypes.Contains(type) ||
               type.IsArray && supportedTypes.Contains(type.GetElementType()!) ||
               type.IsEnum ||
               type.Name == "ActionPreference"; // Handle PowerShell-specific types
    }

    [Fact]
    public async Task CreateLoadAndExecute_DynamicAssemblyWithPowerShellFunction_ShouldSucceed()
    {
        // Arrange - Setup a more complex PowerShell function for testing
        SetupComplexTestPowerShellFunction();
        var commands = GetComplexTestCommands();

        Assert.NotEmpty(commands);
        _output.WriteLine($"Found {commands.Count} PowerShell commands to generate methods for");

        // Act 1: Create the dynamic assembly
        var assembly = PowerShellDynamicAssemblyGenerator.GenerateAssembly(commands, _logger);

        // Assert 1: Verify assembly creation
        Assert.NotNull(assembly);
        Assert.True(assembly.IsDynamic);
        _output.WriteLine($"✓ Created dynamic assembly: {assembly.FullName}");

        // Act 2: Load and get methods from the assembly
        var generatedMethods = PowerShellDynamicAssemblyGenerator.GetGeneratedMethods();
        var instance = PowerShellDynamicAssemblyGenerator.GetGeneratedInstance(_logger);

        // Assert 2: Verify methods and instance
        Assert.NotNull(generatedMethods);
        Assert.NotEmpty(generatedMethods);
        Assert.NotNull(instance);
        _output.WriteLine($"✓ Loaded {generatedMethods.Count} methods from dynamic assembly");

        // Act 3: Get a method representing our PowerShell function
        var methodEntry = generatedMethods.FirstOrDefault();
        Assert.NotEqual(default, methodEntry);
        _output.WriteLine($"Available methods: {string.Join(", ", generatedMethods.Keys)}");

        var methodName = methodEntry.Key;
        var method = methodEntry.Value;
        _output.WriteLine($"✓ Found method: {methodName}");

        // Act 4: Execute the method with parameters (simulating PowerShell function call)
        var parameters = method.GetParameters().Take(method.GetParameters().Length - 1).ToArray(); // Exclude CancellationToken
        var args = new List<object>();

        // Prepare arguments based on our PowerShell function parameters
        foreach (var param in parameters)
        {
            _output.WriteLine($"  Parameter: {param.Name} ({param.ParameterType.Name})");

            if (param.Name == "ProcessName" && param.ParameterType == typeof(string))
            {
                args.Add("notepad");
            }
            else if (param.Name == "IncludeModules" && param.ParameterType == typeof(bool?))
            {
                args.Add(true);
            }
            else if (param.Name == "MaxResults" && (param.ParameterType == typeof(int) || param.ParameterType == typeof(int?)))
            {
                args.Add(5);
            }
            else
            {
                // Default values for other parameter types
                if (param.ParameterType == typeof(string))
                    args.Add("default");
                else if (param.ParameterType == typeof(bool) || param.ParameterType == typeof(bool?))
                    args.Add(false);
                else if (param.ParameterType == typeof(int) || param.ParameterType == typeof(int?))
                    args.Add(0);
                else
                    args.Add(null!);
            }
        }

        // Add CancellationToken as the last parameter
        args.Add(CancellationToken.None);

        _output.WriteLine($"✓ Prepared {args.Count} arguments for method call");

        // Act 5: Invoke the dynamically generated method
        var result = method.Invoke(instance, args.ToArray());
        Assert.NotNull(result);

        // Handle async return type (Task<string>)
        Task<string> taskResult;
        if (result is Task<string> directTask)
        {
            taskResult = directTask;
        }
        else
        {
            // Handle other async patterns
            var taskProperty = result.GetType().GetProperty("Task");
            if (taskProperty != null)
            {
                taskResult = (Task<string>)taskProperty.GetValue(result)!;
            }
            else
            {
                taskResult = Task.FromResult(result.ToString() ?? "");
            }
        }

        var output = await taskResult;

        // Assert 3: Verify execution results
        Assert.NotNull(output);
        Assert.NotEmpty(output);
        _output.WriteLine($"✓ Method execution result: {output}");

        // Verify the output contains expected PowerShell function results
        Assert.True(output.Contains("Process:") || output.Contains("ProcessInfo") || output.Contains("Error") ||
                   output.Contains("Data item") || output.Contains("notepad") || output.Contains("default"),
                   $"Expected output to contain PowerShell function results, but got: {output}");

        _output.WriteLine("✅ Successfully created, loaded, and executed dynamic assembly with PowerShell function!");
    }

    private void SetupComplexTestPowerShellFunction()
    {
        try
        {
            var complexFunctionScript = @"
function Get-ProcessInfo {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$false)]
        [string]$ProcessName = '*',
        
        [Parameter(Mandatory=$false)]
        [bool]$IncludeModules = $false,
        
        [Parameter(Mandatory=$false)]
        [int]$MaxResults = 10
    )
    
    try {
        $processes = @([pscustomobject]@{Name = 'notepad'; id = 0; Modules = @('one', 'two', 'three')}, [pscustomobject]@{Name = 'notepad'; id = 1; Modules = @('four', 'five')})

        if (-not $processes) {
            return ""No processes found matching '$ProcessName'""
        }
        
        $result = @()
        foreach ($proc in $processes) {
            $info = ""Process: $($proc.Name) (PID: $($proc.Id))""
            if ($IncludeModules -and $proc.Modules) {
                $moduleCount = ($proc.Modules | Measure-Object).Count
                $info += "" - Modules: $moduleCount""
            }
            $result += $info
        }
        
        return $result -join ""`n""
    }
    catch {
        return ""Error getting process info: $($_.Exception.Message)""
    }
}";

            var powerShell = PowerShellRunspaceHolder.Instance;
            powerShell.Commands.Clear();
            powerShell.AddScript(complexFunctionScript);
            powerShell.Invoke();
            powerShell.Commands.Clear();

            if (powerShell.HadErrors)
            {
                var errors = powerShell.Streams.Error.ReadAll();
                _output.WriteLine($"Errors setting up complex test function: {string.Join("; ", errors)}");
                powerShell.Streams.Error.Clear();
            }
            else
            {
                _output.WriteLine("Complex test PowerShell function set up successfully");
            }
        }
        catch (Exception ex)
        {
            _output.WriteLine($"Exception setting up complex test function: {ex.Message}");
        }
    }

    private List<CommandInfo> GetComplexTestCommands()
    {
        try
        {
            var powerShell = PowerShellRunspaceHolder.Instance;
            var commands = new List<CommandInfo>();

            // Get the complex test command
            powerShell.Commands.Clear();
            powerShell.AddCommand("Get-Command").AddParameter("Name", "Get-ProcessInfo");
            var cmdInfo = powerShell.Invoke<CommandInfo>().FirstOrDefault();
            powerShell.Commands.Clear();

            if (cmdInfo != null)
            {
                commands.Add(cmdInfo);
                _output.WriteLine($"Found complex test command: {cmdInfo.Name}");
            }
            else
            {
                _output.WriteLine("Complex test command not found");
            }

            return commands;
        }
        catch (Exception ex)
        {
            _output.WriteLine($"Error getting complex test commands: {ex.Message}");
            return new List<CommandInfo>();
        }
    }

    [Fact]
    public void Test_AssemblyIsolation_BetweenTests()
    {
        // This test verifies that each test gets a clean assembly state

        // Arrange - Setup first function
        SetupTestPowerShellFunction();
        var commands1 = GetTestCommands();

        // Act 1 - Generate first assembly
        var assembly1 = PowerShellDynamicAssemblyGenerator.GenerateAssembly(commands1, _logger);
        var methods1 = PowerShellDynamicAssemblyGenerator.GetGeneratedMethods();

        // Assert 1 - Should have our first function
        Assert.NotNull(assembly1);
        Assert.NotEmpty(methods1);
        var firstMethodCount = methods1.Count;
        _output.WriteLine($"First assembly generated with {firstMethodCount} methods: {string.Join(", ", methods1.Keys)}");

        // Arrange - Setup second function (different from first)
        SetupComplexTestPowerShellFunction();
        var commands2 = GetComplexTestCommands();

        // Clear cache to simulate new test
        PowerShellDynamicAssemblyGenerator.ClearCache();

        // Act 2 - Generate second assembly
        var assembly2 = PowerShellDynamicAssemblyGenerator.GenerateAssembly(commands2, _logger);
        var methods2 = PowerShellDynamicAssemblyGenerator.GetGeneratedMethods();

        // Assert 2 - Should be a fresh assembly with only the second function
        Assert.NotNull(assembly2);
        Assert.NotEmpty(methods2);
        _output.WriteLine($"Second assembly generated with {methods2.Count} methods: {string.Join(", ", methods2.Keys)}");

        // Verify isolation - assemblies should be different if they have different commands
        if (commands1.Any() && commands2.Any() &&
            commands1.First().Name != commands2.First().Name)
        {
            Assert.NotEqual(assembly1, assembly2);
            _output.WriteLine("✓ Assembly isolation verified - different assemblies for different command sets");
        }
        else
        {
            _output.WriteLine("ℹ Commands were the same, so assemblies could be equivalent");
        }
    }

    [Fact]
    public async Task McpServer_ShouldExecuteGetSomeDataTool_SuccessfullyInProcess()
    {
        // Clear any cache from previous tests
        PowerShellDynamicAssemblyGenerator.ClearCache();

        // Arrange - Setup the test PowerShell function
        SetupTestPowerShellFunction();

        _output.WriteLine("🚀 Starting in-process MCP server test...");

        // Act 1: Get list of available tools using the static factory
        _output.WriteLine("📋 Step 1: Getting list of available tools");
        var availableTools = McpToolFactoryV2.GetToolsList(_logger);

        Assert.NotNull(availableTools);
        Assert.NotEmpty(availableTools);
        _output.WriteLine($"✓ Found {availableTools.Count} available tools");

        // Log all available tools to help debug
        for (int i = 0; i < availableTools.Count; i++)
        {
            _output.WriteLine($"  Tool {i}: {availableTools[i]}");
        }

        // Act 2: Test the underlying dynamic assembly directly
        _output.WriteLine("📋 Step 2: Testing dynamic assembly methods directly");

        // Get the generated methods and instance
        var generatedMethods = PowerShellDynamicAssemblyGenerator.GetGeneratedMethods();
        var generatedInstance = PowerShellDynamicAssemblyGenerator.GetGeneratedInstance(_logger);

        Assert.NotNull(generatedMethods);
        Assert.NotEmpty(generatedMethods);
        Assert.NotNull(generatedInstance);

        _output.WriteLine($"✓ Found {generatedMethods.Count} generated methods");

        // Find our test method
        var testMethod = generatedMethods.FirstOrDefault(kvp =>
            kvp.Key.Contains("Get_SomeOtherData") || kvp.Key.Contains("SomeOtherData") || kvp.Key.Contains("Get_SomeData"));

        Assert.NotEqual(default, testMethod);
        _output.WriteLine($"✓ Found test method: {testMethod.Key}");

        // Act 3: Call the dynamically generated method with parameters
        _output.WriteLine("📋 Step 3: Calling dynamically generated method");

        var method = testMethod.Value;
        var parameters = method.GetParameters();
        var args = new List<object>();

        _output.WriteLine($" 🔍 Parameter order analysis - Found {parameters.Length} parameters:");
        for (int i = 0; i < parameters.Length; i++)
        {
            _output.WriteLine($"   [{i}] {parameters[i].Name} ({parameters[i].ParameterType.Name})");
        }

        // Build arguments for the method - MATCH BY NAME, NOT POSITION
        foreach (var param in parameters)
        {
            _output.WriteLine($"  Parameter: {param.Name} ({param.ParameterType.Name})");

            // Match parameters by name to avoid ordering issues
            if (param.Name?.Equals("Name", StringComparison.OrdinalIgnoreCase) == true && param.ParameterType == typeof(string))
            {
                args.Add("TestUser");
                _output.WriteLine($"    → Adding Name: TestUser");
            }
            else if (param.Name?.Equals("Count", StringComparison.OrdinalIgnoreCase) == true &&
                     (param.ParameterType == typeof(int) || param.ParameterType == typeof(int?)))
            {
                args.Add(3);
                _output.WriteLine($"    → Adding Count: 3");
            }
            else if (param.ParameterType == typeof(CancellationToken))
            {
                args.Add(CancellationToken.None);
                _output.WriteLine($"    → Adding CancellationToken: None");
            }
            else
            {
                // Default values for other parameter types
                if (param.ParameterType == typeof(string))
                {
                    args.Add("");
                    _output.WriteLine($"    → Adding {param.Name} (string): empty");
                }
                else if (param.ParameterType == typeof(bool) || param.ParameterType == typeof(bool?))
                {
                    args.Add(false);
                    _output.WriteLine($"    → Adding {param.Name} (bool): false");
                }
                else if (param.ParameterType == typeof(int) || param.ParameterType == typeof(int?))
                {
                    args.Add(0);
                    _output.WriteLine($"    → Adding {param.Name} (int): 0");
                }
                else
                {
                    args.Add(null!);
                    _output.WriteLine($"    → Adding {param.Name} ({param.ParameterType.Name}): null");
                }
            }
        }

        _output.WriteLine($"📤 Calling method with {args.Count} arguments: {string.Join(", ", args)}");

        // This is where we can debug into the actual method execution
        var methodResult = method.Invoke(generatedInstance, args.ToArray());

        Assert.NotNull(methodResult);
        _output.WriteLine($"✓ Method invocation completed");

        // Handle async return type
        Task<string> taskResult;
        if (methodResult is Task<string> directTask)
        {
            taskResult = directTask;
        }
        else
        {
            // Handle other async patterns like AsyncTaskMethodBuilder
            var taskProperty = methodResult.GetType().GetProperty("Task");
            if (taskProperty != null)
            {
                taskResult = (Task<string>)taskProperty.GetValue(methodResult)!;
            }
            else
            {
                taskResult = Task.FromResult(methodResult.ToString() ?? "");
            }
        }

        var textContent = await taskResult;

        Assert.NotNull(textContent);
        Assert.NotEmpty(textContent);

        _output.WriteLine($"📥 Method result content: {textContent}");

        // Verify the response contains our expected PowerShell function output
        Assert.True(textContent.Contains("Data item") && textContent.Contains("TestUser"),
            $"Expected method response to contain 'Data item' and 'TestUser', but got: {textContent}");

        _output.WriteLine("✅ In-process MCP tool execution test passed!");

        // Act 4: Verify the tool count matches the method count
        _output.WriteLine("📋 Step 4: Verifying tool and method alignment");
        Assert.Equal(generatedMethods.Count, availableTools.Count);
        _output.WriteLine($"✓ Tool count ({availableTools.Count}) matches method count ({generatedMethods.Count})");
    }
}

/// <summary>
/// Custom logger provider for writing test output
/// </summary>
public class TestOutputLoggerProvider : ILoggerProvider
{
    private readonly ITestOutputHelper _output;

    public TestOutputLoggerProvider(ITestOutputHelper output)
    {
        _output = output;
    }

    public ILogger CreateLogger(string categoryName)
    {
        return new TestOutputLogger(_output, categoryName);
    }

    public void Dispose()
    {
    }
}

/// <summary>
/// Custom logger that writes to test output
/// </summary>
public class TestOutputLogger : ILogger
{
    private readonly ITestOutputHelper _output;
    private readonly string _categoryName;

    public TestOutputLogger(ITestOutputHelper output, string categoryName)
    {
        _output = output;
        _categoryName = categoryName;
    }

    IDisposable? ILogger.BeginScope<TState>(TState state) => null;

    public bool IsEnabled(LogLevel logLevel) => true;

    public void Log<TState>(LogLevel logLevel, EventId eventId, TState state, Exception? exception, Func<TState, Exception?, string> formatter)
    {
        try
        {
            var message = formatter(state, exception);
            _output.WriteLine($"[{logLevel}] {_categoryName}: {message}");

            if (exception != null)
            {
                _output.WriteLine($"Exception: {exception}");
            }
        }
        catch
        {
            // Ignore logging errors during tests
        }
    }
}
