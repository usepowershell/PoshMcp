{
  "Logging": {
    "LogLevel": {
      "Microsoft.AspNetCore": "Warning",
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "PowerShellConfiguration": {
    "CommandNames": [
      "Get-Process"
    ],
    "Modules": [],
