{
  "Logging": {
    "LogLevel": {
      "Microsoft.AspNetCore": "Warning",
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "File": {
      "Path": ""
    }
  },
  "PowerShellConfiguration": {
    "CommandNames": [],
    "Commands": [],
    "Modules": [],
    "ExcludePatterns": [],
    "IncludePatterns": [],
    "EnableDynamicReloadTools": false,
    "Environment": {
      "// Comment": "Install modules from PowerShell Gallery",
      "InstallModules": [
        {
          "Name": "Az.Accounts",
          "Repository": "PSGallery",
          "Scope": "CurrentUser",
          "SkipPublisherCheck": true
        },
        {
          "Name": "Pester",
          "MinimumVersion": "5.0.0",
          "Repository": "PSGallery",
          "Scope": "CurrentUser"
        }
      ],
      "// Comment2": "Import pre-installed or built-in modules",
      "ImportModules": [
        "Microsoft.PowerShell.Management",
        "Microsoft.PowerShell.Utility"
      ],
      "// Comment3": "Add custom module paths (supports environment variables)",
      "ModulePaths": [
        "/mnt/shared-modules",
        "%USERPROFILE%\\MyModules",
        "./custom-modules"
      ],
      "// Comment4": "Inline startup script",
      "StartupScript": "$Global:CompanyName = 'Acme Corp'\nfunction Get-CompanyInfo { return $Global:CompanyName }\nWrite-Host 'Custom environment loaded' -ForegroundColor Green",
      "// Comment5": "Startup script from file",
      "StartupScriptPath": "/config/startup.ps1",
      "// Comment6": "Configuration options (TrustPSGallery is opt-in; default is false)",
      "TrustPSGallery": true,
      "SkipPublisherCheck": true,
      "AllowClobber": false,
      "InstallTimeoutSeconds": 300,
      "SetupTimeoutSeconds": 120
    },
    "Performance": {
      "EnableResultCaching": false,
      "UseDefaultDisplayProperties": true
    },
    "CommandOverrides": {}
  }
}
