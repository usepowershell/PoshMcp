# Example: User-customized PoshMcp Image with Pre-Installed Modules
#
# This Dockerfile demonstrates how to extend the base PoshMcp image with your own customizations:
# - Install PowerShell modules at build time
# - Include custom appsettings.json configuration
# - Add startup scripts or other customizations
#
# Build: docker build -f examples/Dockerfile.user -t my-poshmcp .
# Run:   docker run -d -p 8080:8080 my-poshmcp

# Start from the PoshMcp base image
ARG BASE_IMAGE=ghcr.io/usepowershell/poshmcp/poshmcp:latest
FROM ${BASE_IMAGE}

# Switch to root for installation (base image runs as non-root user)
USER root

# install-modules.ps1 is bundled in the base image at /app/install-modules.ps1
# No COPY needed — it's already available

# $PSModulePath entries available in this image:
#   AllUsers (build + runtime): /usr/local/share/powershell/Modules
#     - install-modules.ps1 installs here by default (Scope=AllUsers)
#     - Writable during USER root build steps; readable by all users at runtime
#   Built-in PowerShell modules: /opt/microsoft/powershell/7/Modules
#     - Ships with the PowerShell apt package (Microsoft.PowerShell.* etc.)
#     - Read-only; do not install modules here
#   CurrentUser (runtime only): /home/appuser/.local/share/powershell/Modules
#     - Only populated if modules are installed at runtime as appuser
#     - Not available during build

# Install your required PowerShell modules
# Modify this line to include the modules your organization needs
ARG INSTALL_PS_MODULES=""
ENV INSTALL_PS_MODULES=${INSTALL_PS_MODULES}
RUN pwsh /app/install-modules.ps1

# (Optional) Copy local modules into the AllUsers path
# COPY MyModule/ /usr/local/share/powershell/Modules/MyModule/
# COPY Modules/ /usr/local/share/powershell/Modules/

# Copy your custom appsettings.json
# Update this path to point to your own appsettings.json file
COPY appsettings.json /app/server/appsettings.json

# (Optional) Copy custom startup scripts
# COPY examples/startup.ps1 /app/startup.ps1

# Switch back to non-root user for runtime security
USER appuser

# The base image already sets ENTRYPOINT and CMD
# No need to redefine them unless you want to override startup behavior
