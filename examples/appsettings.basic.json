{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "PowerShellConfiguration": {
    "FunctionNames": [],
    "Modules": [],
    "Environment": {
      "InstallModules": [
        {
          "Name": "Pester",
          "MinimumVersion": "5.0.0",
          "Repository": "PSGallery",
          "Scope": "CurrentUser"
        }
      ],
      "ImportModules": [
        "Microsoft.PowerShell.Management",
        "Microsoft.PowerShell.Utility"
      ],
      "StartupScript": "Write-Host '✓ Basic environment initialized' -ForegroundColor Green",
      "TrustPSGallery": true,
      "InstallTimeoutSeconds": 300
    }
  }
}
