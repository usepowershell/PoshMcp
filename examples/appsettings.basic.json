{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "PowerShellConfiguration": {
    "FunctionNames": [],
    "Commands": [],
    "Modules": [],
    "ExcludePatterns": [],
    "IncludePatterns": [],
    "EnableDynamicReloadTools": false,
    "Environment": {
      "InstallModules": [
        {
          "Name": "Pester",
          "MinimumVersion": "5.0.0",
          "Repository": "PSGallery",
          "Scope": "CurrentUser"
        }
      ],
      "ImportModules": [
        "Microsoft.PowerShell.Management",
        "Microsoft.PowerShell.Utility"
      ],
      "ModulePaths": [],
      "StartupScript": "Write-Host '✓ Basic environment initialized' -ForegroundColor Green",
      "TrustPSGallery": true,
      "SkipPublisherCheck": true,
      "InstallTimeoutSeconds": 300
    },
    "Performance": {
      "EnableResultCaching": false,
      "UseDefaultDisplayProperties": true
    },
    "FunctionOverrides": {}
  }
}
