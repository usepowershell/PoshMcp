{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "PoshMcp.Server.PowerShell": "Debug"
    }
  },
  "PowerShellConfiguration": {
    "FunctionNames": [],
    "Modules": [],
    "EnableDynamicReloadTools": true,
    "Environment": {
      "InstallModules": [
        {
          "Name": "Az.Accounts",
          "MinimumVersion": "2.0.0",
          "Repository": "PSGallery",
          "Scope": "CurrentUser"
        },
        {
          "Name": "Az.Resources",
          "Repository": "PSGallery",
          "Scope": "CurrentUser"
        },
        {
          "Name": "Az.Storage",
          "Repository": "PSGallery",
          "Scope": "CurrentUser"
        }
      ],
      "ImportModules": [
        "Microsoft.PowerShell.Management",
        "Microsoft.PowerShell.Utility",
        "Microsoft.PowerShell.Security"
      ],
      "ModulePaths": [
        "/mnt/modules",
        "/config/modules"
      ],
      "StartupScriptPath": "/config/startup.ps1",
      "TrustPSGallery": true,
      "AllowClobber": false,
      "InstallTimeoutSeconds": 600
    }
  }
}
